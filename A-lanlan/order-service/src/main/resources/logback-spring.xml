<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- trace_id / span_id 由 OTel Java agent 自动注入 MDC -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %5level [%thread] [trace_id=%X{trace_id} span_id=%X{span_id}] [tenant=%X{tenantId} user=%X{userId}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
